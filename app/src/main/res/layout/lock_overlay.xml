<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lock_background">

    <!-- 中央卡片 -->
    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="36dp"
        android:background="@drawable/bg_card_dark"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lock_title"
            android:textColor="@color/text_white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- 副标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/lock_subtitle"
            android:textColor="@color/lock_text"
            android:textSize="22sp" />

        <!-- 亮度信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_current_lux"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前亮度：12 lux"
                android:textColor="@color/lock_text"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tv_target_lux"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="需要达到：50 lux"
                android:textColor="@color/lock_text"
                android:textSize="20sp" />

            <ProgressBar
                android:id="@+id/progress_lux"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="16dp"
                android:max="50"
                android:progress="12"
                android:progressDrawable="@drawable/progress_lux" />

            <TextView
                android:id="@+id/tv_waiting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/lock_waiting"
                android:textColor="@color/progress_fill"
                android:textSize="18sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="48dp"
        android:paddingBottom="56dp">

        <!-- 手电筒 -->
        <LinearLayout
            android:id="@+id/btn_flashlight"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_circle_white"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔦"
                android:textSize="32sp" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 紧急电话 -->
        <LinearLayout
            android:id="@+id/btn_emergency"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_circle_green"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_call"
                android:contentDescription="紧急电话"
                android:scaleType="centerInside"
                android:tint="@color/text_white" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>

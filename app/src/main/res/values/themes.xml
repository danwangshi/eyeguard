<resources>
    <!-- 应用主题 -->
    <style name="Theme.EyeGuard" parent="Theme.Material3.Light.NoActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>

        <!-- 窗口背景 -->
        <item name="android:windowBackground">@color/background</item>

        <!-- 文字颜色 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- 大按钮样式（老年友好） -->
    <style name="BigButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">72dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:paddingLeft">32dp</item>
        <item name="android:paddingRight">32dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- 大文字样式 -->
    <style name="BigText">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="BigText.White">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_white</item>
    </style>

    <!-- 超大标题 -->
    <style name="HugeTitle">
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_white</item>
    </style>

    <!-- 锁定界面文字 -->
    <style name="LockText">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_gray</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardStyle">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">24dp</item>
    </style>

    <!-- 锁定界面动画 -->
    <style name="LockAnimation">
        <item name="android:windowEnterAnimation">@anim/fade_in</item>
        <item name="android:windowExitAnimation">@anim/fade_out</item>
    </style>
</resources>
